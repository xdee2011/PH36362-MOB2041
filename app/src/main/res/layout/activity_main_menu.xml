<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainMenu">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="MAIN MENU"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- UI: Analytics -->
        <TextView
            android:id="@+id/tvSectionAnalytics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Analytics"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/gridAnalytics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <Button
                android:id="@+id/btnRevenue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Doanh thu"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnTopProducts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Top sản phẩm"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnTopCustomers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Top khách hàng"
                android:textColor="@color/white" />

        </GridLayout>

        <!-- UI: Managing -->
        <TextView
            android:id="@+id/tvSectionManaging"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Managing"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/gridManaging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:rowCount="3"
            android:useDefaultMargins="true">

            <Button
                android:id="@+id/btnProducts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Sản phẩm"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnCustomers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Khách hàng"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnInvoices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Hóa đơn"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnCategories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Danh mục"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnEmployees"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Nhân viên"
                android:textColor="@color/white" />

        </GridLayout>

        <!-- UI: User -->
        <TextView
            android:id="@+id/tvSectionUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="User"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/gridUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Đổi mật khẩu"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:backgroundTint="@color/blue_ocean"
                android:minHeight="48dp"
                android:text="Đăng xuất"
                android:textColor="@color/white" />

        </GridLayout>

    </LinearLayout>
</ScrollView>